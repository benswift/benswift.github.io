{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    ".claude/",
    "backlog/",
    "docs/superpowers/",
    "**/*.deck.mdx",
    "**/decks/**/*.mdx"
  ],
  "svelte": true,
  "overrides": [{ "files": ["**/*.md", "**/*.mdx"], "options": { "printWidth": 80 } }]
}
