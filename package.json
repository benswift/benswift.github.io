{
  "name": "benswift-me",
  "version": "0.0.0",
  "description": "Ben Swift — researcher, educator, artist, developer",
  "license": "MIT",
  "author": "Ben Swift",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "pnpm exec tsx scripts/generate-site-content.ts",
    "build": "astro build && pnpm exec tsx scripts/inject-csp-hashes.ts && pnpm exec pagefind --site dist",
    "site-content": "pnpm exec tsx scripts/generate-site-content.ts",
    "preview": "astro preview",
    "typecheck": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "post": "pnpm exec tsx scripts/new-post.ts",
    "gen:default-hero": "pnpm exec tsx scripts/generate-default-hero.ts",
    "gen:hero-images": "pnpm exec tsx scripts/generate-hero-images.ts",
    "lighthouse": "pnpm exec tsx scripts/lighthouse-audit.ts",
    "atproto:publish": "pnpm exec tsx scripts/atproto-publish.ts",
    "atproto:livecoding": "pnpm exec tsx scripts/atproto-livecoding.ts",
    "atproto:lexicon": "pnpm exec tsx scripts/publish-lexicon.ts",
    "atproto:seed": "pnpm exec tsx scripts/seed-syndication.ts",
    "archive:urls": "pnpm exec tsx scripts/archive-event-urls.ts",
    "zenodo:deposit": "pnpm exec tsx scripts/zenodo-deposit.ts",
    "zenodo:collection": "pnpm exec tsx scripts/zenodo-collection.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@mediapipe/tasks-genai": "^0.10.27",
    "astro-broken-links-checker": "^1.1.0",
    "astro-theme-anu": "git+https://gitlab.anu.edu.au/u2548636/astro-theme-anu.git#astro-theme-anu@v0.7.0&path:/packages/astro-theme-anu",
    "astromotion": "git+https://github.com/benswift/astromotion.git#v0.9.1",
    "perceptron-apparatus": "github:ANUcybernetics/perceptron-apparatus",
    "remark-smartypants": "^3.0.2",
    "shaderpad": "1.0.0-beta.85",
    "sharp": "^0.34.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/markdown-satteri": "^0.3.1",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.0",
    "@atproto/api": "^0.20.6",
    "@e18e/eslint-plugin": "^0.5.0",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.1",
    "@types/unist": "^3.0.3",
    "astro": "^7.0.0",
    "astro-icon": "^1.1.5",
    "bibtex-parse": "^2.1.0",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "pagefind": "^1.5.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.55.10",
    "svelte-check": "^4.4.8",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "engines": {
    "pnpm": ">=11"
  }
}
