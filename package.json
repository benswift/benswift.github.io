{
  "name": "benswift-me",
  "version": "0.0.0",
  "description": "Ben Swift — researcher, educator, artist, developer",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && pnpm exec pagefind --site dist",
    "preview": "astro preview",
    "typecheck": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "post": "pnpm exec tsx scripts/new-post.ts",
    "lighthouse": "pnpm exec tsx scripts/lighthouse-audit.ts",
    "atproto:publish": "pnpm exec tsx scripts/atproto-publish.ts",
    "test": "vitest run",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "author": "Ben Swift",
  "license": "MIT",
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.1",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/svelte": "^8.0.1",
    "@atproto/api": "^0.19.3",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@types/node": "^25.5.0",
    "@types/three": "^0.183.1",
    "astro": "^6.0.5",
    "astro-icon": "^1.1.5",
    "bibtex-parse": "^2.1.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gray-matter": "^4.0.3",
    "oxlint": "^1.56.0",
    "pagefind": "^1.4.0",
    "remark-directive": "^4.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@fontsource-variable/atkinson-hyperlegible-mono": "^5.2.5",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "astro-broken-links-checker": "^1.0.7",
    "remark-smartypants": "^3.0.2",
    "sharp": "^0.34.5",
    "three": "^0.183.2"
  }
}
