{
  "name": "benswift-me",
  "version": "0.0.0",
  "description": "Ben Swift — researcher, educator, artist, developer",
  "license": "MIT",
  "author": "Ben Swift",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "pnpm exec tsx scripts/generate-site-content.ts",
    "build": "astro build && pnpm exec pagefind --site dist",
    "site-content": "pnpm exec tsx scripts/generate-site-content.ts",
    "preview": "astro preview",
    "typecheck": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "post": "pnpm exec tsx scripts/new-post.ts",
    "lighthouse": "pnpm exec tsx scripts/lighthouse-audit.ts",
    "atproto:publish": "pnpm exec tsx scripts/atproto-publish.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@fontsource-variable/atkinson-hyperlegible-mono": "^5.2.5",
    "@fontsource-variable/atkinson-hyperlegible-next": "^5.2.6",
    "@mediapipe/tasks-genai": "^0.10.27",
    "astro-broken-links-checker": "^1.0.7",
    "astromotion": "github:benswift/astromotion",
    "perceptron-apparatus": "github:ANUcybernetics/perceptron-apparatus",
    "remark-smartypants": "^3.0.2",
    "sharp": "^0.34.5",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/svelte": "^8.0.4",
    "@atproto/api": "^0.19.6",
    "@e18e/eslint-plugin": "^0.3.0",
    "@iconify-json/fa6-brands": "^1.2.6",
    "@iconify-json/fa6-solid": "^1.2.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.5.2",
    "@types/three": "^0.183.1",
    "@types/unist": "^3.0.3",
    "astro": "^6.1.4",
    "astro-icon": "^1.1.5",
    "bibtex-parse": "^2.1.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "gray-matter": "^4.0.3",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "pagefind": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.32.1"
}
