{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  // Shared baseline across the theme-family repos — keep in step with the
  // other sites (the anu-theme-sync skill owns the canon). Repo-specific
  // deltas go below the marked line.
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error"
  },
  "plugins": ["typescript", "import", "unicorn"],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true,
    "es2024": true
  },
  "jsPlugins": [
    "@e18e/eslint-plugin",
    "eslint-plugin-no-only-tests",
    "eslint-plugin-perfectionist",
    "eslint-plugin-unused-imports"
  ],
  "rules": {
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-warning-comments": ["error", { "terms": ["@nocommit"] }],
    "import/no-self-import": "error",
    "no-only-tests/no-only-tests": "error",
    "unused-imports/no-unused-imports": "error",
    "perfectionist/sort-named-imports": "error",
    "perfectionist/sort-heritage-clauses": "error",
    // the e18e "recommended" preset, enumerated because oxlint's jsPlugins
    // bridge can't consume ESLint flat-config presets — minus
    // prefer-static-regex, whose module-scope-hoisting churn (~260 sites
    // family-wide, mostly tests and build scripts) isn't worth the perf
    "e18e/ban-dependencies": "error",
    "e18e/prefer-array-at": "error",
    "e18e/prefer-array-fill": "error",
    "e18e/prefer-array-from-map": "error",
    "e18e/prefer-array-some": "error",
    "e18e/prefer-array-to-reversed": "error",
    "e18e/prefer-array-to-sorted": "error",
    "e18e/prefer-array-to-spliced": "error",
    "e18e/prefer-date-now": "error",
    "e18e/prefer-includes": "error",
    "e18e/prefer-nullish-coalescing": "error",
    "e18e/prefer-object-has-own": "error",
    "e18e/prefer-regex-test": "error",
    "e18e/prefer-spread-syntax": "error",
    "e18e/prefer-string-fromcharcode": "error",
    "e18e/prefer-timer-args": "error",
    "e18e/prefer-url-canparse": "error",
    // --- repo-specific deltas below ---
    "no-console": "off", // this site logs deliberately in build/data scripts
    "no-await-in-loop": "off", // deliberate sequential awaits in scripts (rate limits, ordered writes)
    "import/no-namespace": "error"
  },
  "overrides": [
    {
      "files": ["**/*.svelte"],
      "rules": {
        // imports used only in the template are invisible to the JS-block
        // linter, so this rule false-positives on every component
        "unused-imports/no-unused-imports": "off"
      }
    }
  ],
  "ignorePatterns": [
    "dist/",
    ".astro/",
    "**/*.astro",
    "public/assets/js/Winwheel.js",
    "**/*.svelte" // this repo deliberately ignores svelte files in oxlint
  ]
}
