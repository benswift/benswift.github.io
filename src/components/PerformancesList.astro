---
import { getCollection } from "astro:content"

const allGigs = await getCollection("livecoding")

const gigs = allGigs
  .map((gig) => {
    const slug = gig.id.replace(/\.md$/, "")
    let dateStr = "2000-01-01"
    const filenameMatch = gig.id.match(/^(\d{4}-\d{2}-\d{2})/)
    if (filenameMatch) dateStr = filenameMatch[1]
    else if (gig.data.date) dateStr = String(gig.data.date)
    const year = dateStr.slice(0, 4)

    return {
      title: gig.data.title,
      url: `/livecoding/${slug}/`,
      dateStr,
      year,
      venue: gig.data.venue,
      artists: gig.data.artists,
      event: gig.data.event,
      event_url: gig.data.event_url,
      video_url: gig.data.video_url,
      type: gig.data.type,
    }
  })
  .sort((a, b) => b.dateStr.localeCompare(a.dateStr))

const gigsByYear: Record<string, typeof gigs> = {}
for (const gig of gigs) {
  if (!gigsByYear[gig.year]) gigsByYear[gig.year] = []
  gigsByYear[gig.year].push(gig)
}
const years = Object.keys(gigsByYear).sort((a, b) => b.localeCompare(a))
---

<div class="bibliography">
  {years.map((year) => (
    <div class="year-section">
      <h3 id={`perf-${year}`}>{year}</h3>
      {gigsByYear[year].map((gig) => (
        <div class="pub-item">
          <p class="pub-title">
            <a href={gig.url}>{gig.title}</a>
          </p>
          <p class="pub-authors">
            Ben Swift{gig.artists && gig.artists.length > 0 && `, ${gig.artists.join(", ")}`}
          </p>
          {gig.event && (
            <p class="pub-venue">
              {gig.event_url ? (
                <a href={gig.event_url} target="_blank">{gig.event}</a>
              ) : (
                gig.event
              )}
            </p>
          )}
          {gig.venue && <p class="pub-venue">{gig.venue}</p>}
          {gig.video_url && (
            <p class="pub-pdf">
              <a href={gig.video_url} target="_blank">video</a>
            </p>
          )}
        </div>
      ))}
    </div>
  ))}
</div>
