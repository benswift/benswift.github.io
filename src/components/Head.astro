---
import { getPublicationAtUri } from "../utils/atproto"

interface Props {
  title?: string
  description?: string
  image: string
  isPost?: boolean
  date?: string
  atUri?: string
}

const { title, description, image, isPost = false, date, atUri } = Astro.props

// Bluesky's enhanced link cards verify articles against BOTH the document and
// publication records, so the two rel tags travel together.
const publicationAtUri = atUri ? getPublicationAtUri() : undefined

const siteTitle = "benswift.me"
const hostname = "https://benswift.me"

const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle
const url = new URL(Astro.url.pathname, hostname).href
const imageUrl = image.startsWith("http") ? image : `${hostname}${image}`
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="color-scheme" content="dark" />
{/*
  Content Security Policy. Authored as a meta tag rather than via
  security.csp because Astro 6's built-in CSP doesn't yet support the
  ClientRouter or Shiki (the docs say so explicitly). script-src is the
  tight one — only self-bundled modules and the pinned jsDelivr juttu are
  allowed. style-src needs 'unsafe-inline' for Shiki's per-token style
  attributes. The wider connect-src/frame-src/worker-src exist for the
  on-device Gemma demo (Hugging Face model fetch, @mediapipe wasm worker)
  and the YouTube embeds. frame-ancestors isn't honored from <meta>; GitHub
  Pages doesn't let us set headers, so clickjacking protection here is
  on the host, not on us.
*/}
<meta
  http-equiv="Content-Security-Policy"
  content="default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https:; frame-src https://www.youtube-nocookie.com; worker-src 'self' blob:; child-src 'self' blob:; base-uri 'self'; form-action 'self'; object-src 'none'"
/>
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="alternate" type="application/rss+xml" title="benswift.me" href="/feed.xml" />
<title>{pageTitle}</title>

<meta name="author" content="Ben Swift" />
{description && <meta name="description" content={description} />}

<!-- Open Graph -->
<meta property="og:url" content={url} />
<meta property="og:type" content={isPost ? "article" : "website"} />
<meta property="og:site_name" content={siteTitle} />
{title && <meta property="og:title" content={title} />}
{description && <meta property="og:description" content={description} />}
<meta property="og:image" content={imageUrl} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@benswift" />
{title && <meta name="twitter:title" content={title} />}
{description && <meta name="twitter:description" content={description} />}
<meta name="twitter:image" content={imageUrl} />

<!-- AT Protocol -->
{atUri && <link rel="site.standard.document" href={atUri} />}
{publicationAtUri && <link rel="site.standard.publication" href={publicationAtUri} />}

<!-- Juttu comments (AT Protocol powered) -->
{atUri && <script is:inline defer src="https://cdn.jsdelivr.net/npm/juttu@0.3.5/juttu-embed.js" integrity="sha384-5QRt2ZnQcKVdUqttMGfMmfMpcn2BzEI7rqmxoPtY2Z/pqgoUaAwpoBolPJg61EKD" crossorigin="anonymous" data-theme="dark"></script>}

<!-- Citation metadata -->
{isPost && title && <meta name="citation_title" content={title} />}
{isPost && <meta name="citation_author" content="Ben Swift" />}
{isPost && date && <meta name="citation_date" content={date} />}
{isPost && <meta name="citation_public_url" content={url} />}
