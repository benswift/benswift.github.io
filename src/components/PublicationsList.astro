---
import { loadPublications } from "../data/bibliography"

const pubs = loadPublications()

const pubsByYear: Record<string, typeof pubs> = {}
for (const pub of pubs) {
  if (!pubsByYear[pub.year]) pubsByYear[pub.year] = []
  pubsByYear[pub.year].push(pub)
}
const years = Object.keys(pubsByYear).sort((a, b) => b.localeCompare(a))
---

<div class="bibliography">
  {years.map((year) => (
    <div class="year-section">
      <h3 id={year}>{year}</h3>
      <ul class="pub-list">
        {pubsByYear[year].map((pub) => (
          <li class="pub-item" id={pub.key}>
            <p class="pub-title">
              {pub.doi ? (
                <a href={`https://doi.org/${pub.doi}`} target="_blank" rel="noopener">{pub.title}</a>
              ) : pub.url ? (
                <a href={pub.url} target="_blank" rel="noopener">{pub.title}</a>
              ) : (
                <span>{pub.title}</span>
              )}
            </p>
            <p class="pub-authors">{pub.authors}</p>
            {pub.venue && <p class="pub-venue">{pub.venue}</p>}
            {pub.pdfPath && (
              <p class="pub-pdf">
                <a href={pub.pdfPath} target="_blank" rel="noopener" aria-label={`Download PDF: ${pub.title}`}>PDF</a>
              </p>
            )}
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
