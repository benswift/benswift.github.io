---
import { Image } from "astro:assets"
import type { ImageMetadata } from "astro"

interface Props {
  file: string
  alt?: string
  credit?: string
}

const { file, alt = "", credit } = Astro.props

// Discover post images at build time. Path is relative to
// src/assets/post-images/ (e.g. "posts/foo.webp", "livecoding/bar.webp").
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/post-images/**/*.{png,jpg,jpeg,webp,avif,gif}",
  { eager: true, import: "default" },
)

const key = `/src/assets/post-images/${file}`
const image = imageModules[key]?.default ?? (imageModules[key] as unknown as ImageMetadata)

if (!image) {
  throw new Error(
    `Picture: image not found at ${key}. Available keys start with "/src/assets/post-images/".`,
  )
}

// Animated GIFs lose animation when re-encoded; pass through as raw <img>.
const isGif = image.format === "gif"
---

<figure class="picture-container">
  {
    isGif ? (
      <img src={image.src} alt={alt} loading="lazy" width={image.width} height={image.height} />
    ) : (
      <Image src={image} alt={alt} loading="lazy" />
    )
  }
  {credit && <figcaption class="picture-credit">{credit}</figcaption>}
</figure>

<style>
  .picture-container {
    position: relative;
    margin: 1rem 0;
  }

  .picture-container img {
    width: 100%;
    height: auto;
    display: block;
  }

  .picture-credit {
    position: absolute;
    bottom: 1em;
    right: 1em;
    color: #ffffff;
    font-weight: 200;
    font-size: 0.875rem;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }

  .picture-credit::before {
    content: "photo: ";
  }
</style>
