---
import "../styles/global.css"
import type { ImageMetadata } from "astro"
import { Font, getImage } from "astro:assets"
import Head from "../components/Head.astro"
import Nav from "../components/Nav.astro"
import HeroCanvas from "../components/svelte/HeroCanvas.svelte"
import { ClientRouter } from "astro:transitions"
import { SITE_BASELINE_PHRASES } from "../data/hero"
import defaultHero from "../assets/og-default.avif"

interface Props {
  title?: string
  description?: string
  image?: string
  isPost?: boolean
  date?: string
  atUri?: string
  phrases?: string[]
  heroImage?: ImageMetadata
}

const {
  title,
  description,
  image,
  isPost,
  date,
  atUri,
  phrases = [...SITE_BASELINE_PHRASES],
  heroImage = defaultHero,
} = Astro.props

// WebP, not PNG: the og:image (also twitter:image) is only ever fetched by link
// unfurlers and reduced-motion users, and WebP is ~35x smaller than PNG here
// (~15 KB vs ~530 KB) while still decoding on every platform that previews links.
const ogImage = await getImage({ src: heroImage, format: "webp", width: 1200, quality: 80 })
const heroFallbackImage = await getImage({
  src: heroImage,
  format: "avif",
  width: 1280,
  quality: 50,
})
const heroPhrasesContent = phrases.join("|")
---

<html lang="en">
  <head>
    <Font cssVariable="--font-fraunces" preload={[{ style: "normal" }]} />
    <Font cssVariable="--font-atkinson-mono" preload />
    <Head
      title={title}
      description={description}
      image={image ?? ogImage.src}
      isPost={isPost}
      date={date}
      atUri={atUri}
    />
    <meta name="hero-phrases" content={heroPhrasesContent} />
    <meta name="hero-image-url" content={heroFallbackImage.src} />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <div class="hero-slot" aria-hidden="true">
      <HeroCanvas client:only="svelte" transition:persist="hero-canvas" />
    </div>
    <Nav />
    <main id="main-content" tabindex="-1" data-pagefind-body>
      <slot />
    </main>
  </body>
</html>
