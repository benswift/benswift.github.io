---
import BaseLayout from "./BaseLayout.astro"
import SiteFooter from "../components/SiteFooter.astro"

interface Props {
  title?: string
  description?: string
  relativePath?: string
  frontmatter?: {
    title?: string
    description?: string
    relativePath?: string
  }
}

const props = Astro.props
const title = props.title ?? props.frontmatter?.title
const description = props.description ?? props.frontmatter?.description
const relativePath = props.relativePath ?? props.frontmatter?.relativePath
---

<BaseLayout title={title} description={description}>
  {title && <h1 class="page-title">{title}</h1>}
  <slot />
  <SiteFooter relativePath={relativePath} />
</BaseLayout>
