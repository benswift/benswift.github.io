---
import type { ImageMetadata } from "astro"
import BaseLayout from "./BaseLayout.astro"
import TagList from "../components/TagList.astro"
import CitePost from "../components/CitePost.astro"
import SiteFooter from "../components/SiteFooter.astro"
import { formatDate, parseDate } from "../utils/date"
import { getHeroImage } from "../utils/hero-image"
import { SITE_BASELINE_PHRASES } from "../data/hero"

interface Props {
  title: string
  date: string
  tags: string[]
  description?: string
  heroPhrases?: string[]
  atUri?: string
  slug: string
  relativePath: string
  heroImage?: ImageMetadata
}

const {
  title,
  date,
  tags,
  description,
  heroPhrases,
  atUri,
  slug,
  relativePath,
  heroImage: heroImageOverride,
} = Astro.props

const postDate = formatDate(parseDate(date), true)
const postUrl = `https://benswift.me${Astro.url.pathname}`

const heroSlug = `${date}-${slug}`
const heroImage = heroImageOverride ?? getHeroImage(heroSlug)
const phrases = [...SITE_BASELINE_PHRASES, ...tags, ...(heroPhrases ?? [])]
---

<BaseLayout
  title={title}
  description={description}
  isPost={true}
  date={date}
  atUri={atUri}
  phrases={phrases}
  heroImage={heroImage}
>
  <h1 class="page-title">{title}</h1>
  <p class="post-date">{postDate}</p>
  <TagList tags={tags} />
  <div class="post-content">
    <slot />
  </div>
  {atUri && <div id="juttu-comments"></div>}
  <script>
    // The juttu embed hard-codes its submit button label and re-sets it after
    // every "Posting…" cycle, so relabelling needs an observer, not a one-shot
    // rename. Sized to match the sort pills in global.css.
    function initJuttuRelabel() {
      const container = document.getElementById("juttu-comments")
      if (!container || container.dataset.relabelBound) return
      container.dataset.relabelBound = "1"
      const relabel = () => {
        container.querySelectorAll(".juttu-submit-btn").forEach(btn => {
          if (btn.textContent === "Post comment") btn.textContent = "Post"
        })
      }
      relabel()
      new MutationObserver(relabel).observe(container, {
        childList: true,
        subtree: true,
        characterData: true,
      })
    }
    initJuttuRelabel()
    document.addEventListener("astro:page-load", initJuttuRelabel)
  </script>
  <CitePost title={title} date={date} slug={slug} url={postUrl} atUri={atUri} />
  <SiteFooter relativePath={relativePath} />
</BaseLayout>
