---
import BaseLayout from "./BaseLayout.astro"
import SiteFooter from "../components/SiteFooter.astro"

interface Props {
  description?: string
  image?: string
  frontmatter?: {
    description?: string
    image?: string
  }
}

const props = Astro.props
const description = props.description ?? props.frontmatter?.description
const image = props.image ?? props.frontmatter?.image
---

<BaseLayout description={description} image={image}>
  {image && <img class="home-hero-svg" src={image} alt="" />}
  <div class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1 class="hero-name">Ben Swift</h1>
        <p class="hero-tagline">researcher, educator, artist, developer</p>
        <p class="hero-subtitle">Leading <em>Human-Scale AI</em> at the Cybernetic Studio</p>
      </div>
    </div>
  </div>

  <div class="features">
    <a href="/blog/" class="feature-card">
      <h2>Blog</h2>
      <p>Thoughts on research, art, code, teaching and whatever else is keeping me up at night.</p>
    </a>
    <a href="/research/" class="feature-card">
      <h2>Research</h2>
      <p>Peer-reviewed publications on AI/LLMs, creative computing, and human-computer interaction.</p>
    </a>
    <a href="/teaching/" class="feature-card">
      <h2>Teaching</h2>
      <p>Courses on agentic coding, creative computing, and cybernetics.</p>
    </a>
    <a href="/livecoding/" class="feature-card">
      <h2>Livecoding</h2>
      <p>Curated and invited livecoding performances around the world.</p>
    </a>
  </div>

  <slot />
  <SiteFooter relativePath="src/pages/index.md" />
</BaseLayout>

<style>
  .hero {
    margin-bottom: 2rem;
  }

  .home-hero-svg {
    width: 100%;
    height: auto;
    border-radius: 8px 0 8px 8px;
    margin-bottom: 1.5rem;
  }

  .hero-name {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0;
    color: var(--highlight-color);
  }

  .hero-tagline {
    font-size: 1.25rem;
    color: var(--text-grey);
    margin: 0.5rem 0;
  }

  .hero-subtitle {
    margin: 0.5rem 0 1rem;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin: 2rem 0;
  }

  .feature-card {
    padding: 1.25rem;
    border-radius: 8px 0 8px 8px;
    text-decoration: none;
    color: var(--text-color);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 1px 2px rgba(0, 0, 0, 0.2),
      0 4px 12px rgba(0, 0, 0, 0.15);
    transition: box-shadow 0.2s;
  }

  .feature-card:hover {
    box-shadow:
      0 0 0 1px var(--highlight-color),
      0 2px 4px rgba(0, 0, 0, 0.25),
      0 8px 24px rgba(0, 0, 0, 0.2);
    color: var(--text-color);
  }

  .feature-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.1rem;
  }

  .feature-card p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-2);
  }
</style>
