---
// Subtle per-talk timer overlay for the PhD offsite deck.
//
// Rendered as a plain (non-hydrated) component: astromotion's slide splitter
// wraps deck imports into a Reveal <section>, which trips Astro's
// client-directive import check (it only sees root-level imports). A static
// .astro component with a bundled <script> sidesteps that entirely while still
// shipping client JS.
//
// The script builds a fixed overlay on <body> (so it survives Reveal hiding
// the off-screen slides). The talk clock is FULLY manual: S (or clicking the
// widget) starts it as the speaker begins — capturing that segment's
// allotment — and pressing S again stops it when they finish. Navigation
// never starts, stops, or resets a running clock, so jumping around the deck
// mid-talk (even into someone else's slides) is safe; when idle, the widget
// previews the on-screen segment's allotment. There is deliberately no
// absolute day clock or drift tracking: with manual starts, "are we behind"
// is the wall clock's job — astromotion's own, bottom-right on T. The
// countdown measures the TALK, not the slot: it hits 0:00 and goes RED at
// question time (12:00 / 4:00 elapsed for the 12+3 / 4+1 slots), then runs
// negative through Q&A, so -1:30 reads as "a minute and a half past your
// talk". From the play-off mark (13:00 / 4:30 elapsed, i.e. -1:00 / -0:30 on
// the countdown) the music (Spanish Flea) plays until the next slide advance
// stops it. The ± buttons (or -/+ keys) rejig the on-screen segment's
// allotment a minute at a time, live and mid-talk if need be; the adjustment
// sticks to that segment and moves its play-off mark with it. Controls: S
// starts/stops the talk clock, -/+ adjust the allotment, M mutes the music,
// H hides the widget.
---

<div id="offsite-timer-mount" hidden></div>

<script>
  import playoffTrack from "./assets/playoff-spanish-flea.opus";

  interface Segment {
    id: string;
    label: string;
    start: string; // scheduled start — documentation only, not used by logic
    mins: number;
    qa?: number; // minutes reserved for questions at the end of the slot
    playoff?: number; // elapsed minutes when the play-off music starts
    // (defaults to the full slot, i.e. music only on overrun)
  }

  // The day's program. Each `id` matches a `seg-<id>` class on that segment's
  // divider slide in slides.deck.mdx. Talks are 12+3 (15 min) and 4+1 (5 min);
  // the countdown goes red at question time (12:00 / 4:00), and the play-off
  // starts at 13:00 / 4:30, playing until a slide advance stops it.
  const SCHEDULE: Segment[] = [
    { id: "intro", label: "Welcome & intro", start: "09:00", mins: 15 },
    { id: "evan", label: "Evan Skinner", start: "09:15", mins: 15, qa: 3, playoff: 13 },
    { id: "jake", label: "Jake Blight", start: "09:30", mins: 15, qa: 3, playoff: 13 },
    { id: "amy", label: "Amy Wardrop", start: "09:45", mins: 15, qa: 3, playoff: 13 },
    { id: "tom-chan", label: "Tom Chan", start: "10:00", mins: 15, qa: 3, playoff: 13 },
    { id: "bek", label: "Bek Conroy", start: "10:15", mins: 15, qa: 3, playoff: 13 },
    { id: "break-am", label: "Morning tea", start: "10:30", mins: 15 },
    { id: "matthew", label: "Matthew Heffernan", start: "10:45", mins: 15, qa: 3, playoff: 13 },
    { id: "bill", label: "Bill McAlister", start: "11:00", mins: 15, qa: 3, playoff: 13 },
    { id: "liz", label: "Liz Skelton", start: "11:15", mins: 15, qa: 3, playoff: 13 },
    { id: "dominika", label: "Dominika Janus", start: "11:30", mins: 15, qa: 3, playoff: 13 },
    { id: "break-mid", label: "Short break", start: "11:45", mins: 15 },
    { id: "charlie", label: "Charlie Paulk", start: "12:00", mins: 5, qa: 1, playoff: 4.5 },
    { id: "joshua", label: "Joshua Castle", start: "12:05", mins: 5, qa: 1, playoff: 4.5 },
    { id: "griffiths", label: "Thomas Griffiths", start: "12:10", mins: 5, qa: 1, playoff: 4.5 },
    { id: "sui", label: "Sui Jackson", start: "12:15", mins: 5, qa: 1, playoff: 4.5 },
    { id: "gareth", label: "Gareth Jones", start: "12:20", mins: 5, qa: 1, playoff: 4.5 },
    { id: "nadereh", label: "Nadereh Ghelich Khani", start: "12:25", mins: 5, qa: 1, playoff: 4.5 },
    { id: "mcevoy", label: "Thomas McEvoy Zafiropulos", start: "12:30", mins: 5, qa: 1, playoff: 4.5 },
    { id: "zhuotao", label: "Zhuotao Fang", start: "12:35", mins: 5, qa: 1, playoff: 4.5 },
    { id: "lunch", label: "Lunch", start: "12:45", mins: 60 },
    { id: "skills", label: "Skills: working with Claude", start: "13:45", mins: 90 },
    { id: "break-pm", label: "Afternoon tea", start: "15:15", mins: 15 },
    { id: "admin", label: "Admin updates", start: "15:30", mins: 15 },
    { id: "discussion", label: "Discussion & feedback", start: "15:45", mins: 45 },
    { id: "wrap", label: "Wrap-up & close", start: "16:30", mins: 15 },
  ];

  const byId = new Map(SCHEDULE.map((s) => [s.id, s]));

  const fmt = (sec: number) => {
    const neg = sec < 0;
    const s = Math.abs(Math.round(sec));
    return `${neg ? "-" : ""}${Math.floor(s / 60)}:${(s % 60).toString().padStart(2, "0")}`;
  };

  // --- overlay ------------------------------------------------------------
  const el = document.createElement("div");
  el.className = "offsite-timer idle";
  el.setAttribute("role", "button");
  el.tabIndex = -1;
  el.title =
    "Click or press S when the speaker starts, and again when they finish. -/+ adjust this segment by a minute. M mutes the play-off music, H hides.";
  el.innerHTML =
    '<div class="row">' +
    '<div class="adj">' +
    '<button type="button" class="adj-btn" data-delta="-1" tabindex="-1" title="One minute less for this segment">−</button>' +
    '<button type="button" class="adj-btn" data-delta="1" tabindex="-1" title="One minute more for this segment">+</button>' +
    "</div>" +
    '<div class="count count-idle">—:—</div>' +
    "</div>" +
    '<div class="status status-idle"><span class="dot"></span>ready</div>';
  document.body.appendChild(el);
  const countEl = el.querySelector(".count") as HTMLElement;
  const statusEl = el.querySelector(".status") as HTMLElement;

  let currentId: string | null = null;
  let talkStart: number | null = null;
  let runningSeg: Segment | null = null;
  let musicDone = false;
  // Per-segment allotment tweaks, in seconds: rejigging on the fly sticks to
  // the segment it was made against, so navigating away and back keeps it.
  const adjust = new Map<string, number>();
  const adjustOf = (seg: Segment | null) => (seg ? (adjust.get(seg.id) ?? 0) : 0);

  const detectSeg = (): string | null => {
    let s: Element | null =
      document.querySelector(".reveal .slides section.present") ??
      document.querySelector(".reveal .slides > section");
    for (; s; s = s.previousElementSibling) {
      const m = s.className.match(/\bseg-([a-z0-9-]+)\b/);
      if (m) return m[1];
    }
    return null;
  };

  // --- play-off music -------------------------------------------------------
  // "Spanish Flea" (Herb Alpert), looping via a plain <audio> element (same
  // pattern as llms-unplugged's BgMusic). ensureAudio() primes playback on
  // the first S press so the browser's autoplay policy is satisfied by a
  // user gesture before the play-off mark ever arrives.
  let muted = false;
  let playing = false;
  let primed = false;

  const audio = new Audio(playoffTrack);
  audio.loop = true;
  audio.preload = "auto";

  const ensureAudio = () => {
    if (primed) return;
    primed = true;
    // play/pause once at zero volume inside the user gesture — unlocks
    // playback for the later programmatic start
    audio.volume = 0;
    audio
      .play()
      .then(() => {
        audio.pause();
        audio.currentTime = 0;
      })
      .catch(() => {});
  };

  // Fixed volume — no swell. By the play-off mark they're already a minute
  // over, and the track eases in on its own anyway.
  const startMusic = () => {
    if (playing || muted) return;
    playing = true;
    audio.currentTime = 0;
    audio.volume = 0.7;
    audio.play().catch(() => {});
  };

  const stopMusic = () => {
    if (!playing) return;
    playing = false;
    audio.pause();
  };

  // --- render ---------------------------------------------------------------
  const setClass = (node: HTMLElement, base: string, state: string) => {
    node.className = `${base} ${base}-${state}`;
  };

  const setStatus = (state: string, text: string) => {
    setClass(statusEl, "status", state);
    statusEl.innerHTML = "";
    const d = document.createElement("span");
    d.className = "dot";
    statusEl.appendChild(d);
    statusEl.appendChild(document.createTextNode(text));
  };

  const render = () => {
    // A running clock belongs to the segment captured when S was pressed;
    // navigating anywhere else never touches it. When idle, preview the
    // allotment of whatever segment is on screen.
    const running = talkStart != null && runningSeg != null;
    const seg = running ? runningSeg : currentId ? (byId.get(currentId) ?? null) : null;
    el.classList.toggle("idle", !running);

    if (!seg) {
      countEl.textContent = "—:—";
      setClass(countEl, "count", "idle");
      setStatus("idle", "ready");
      stopMusic();
      return;
    }

    // The countdown measures the TALK, not the slot: it hits 0:00 at question
    // time and runs negative from there, so a glance at a red -1:30 says
    // exactly how far past their talk the speaker is. Q&A is the tail between
    // zero and the end of the slot; past that it's genuine overtime.
    // A ±adjustment stretches (or shrinks) the talk: the countdown and the
    // play-off mark move together, so the speaker keeps the same run-up to the
    // music, and question time stays a fixed tail on the end.
    const adj = adjustOf(seg);
    const spent = running ? (Date.now() - talkStart!) / 1000 : 0;
    const qaSec = (seg.qa ?? 0) * 60;
    const remaining = seg.mins * 60 + adj - qaSec - spent;
    const playoffSec = (seg.playoff ?? seg.mins) * 60 + adj;
    countEl.textContent = fmt(remaining);

    // Music runs from the play-off mark until a slide advance kills it
    // (musicDone) for the rest of this talk.
    const playingOff = running && !musicDone && spent >= playoffSec;
    if (playingOff && !muted) {
      startMusic();
    } else {
      stopMusic();
    }

    const tag = adj ? ` ${adj > 0 ? "+" : "−"}${Math.abs(adj) / 60}` : "";
    if (!running) {
      setClass(countEl, "count", "idle");
      setStatus("idle", `S starts${tag}`);
    } else if (remaining <= 0 && -remaining < qaSec) {
      setClass(countEl, "count", "over");
      setStatus("over", `questions${tag}`);
    } else if (remaining <= 0) {
      setClass(countEl, "count", "over");
      setStatus("over", `overtime${tag}`);
    } else {
      setClass(countEl, "count", "ok");
      setStatus("ok", `talk${tag}`);
    }
  };

  const onSlide = () => {
    // Navigation NEVER starts, stops, or re-arms the clock — jumping around
    // the deck mid-talk is safe. Its only effect: a slide advance while the
    // play-off is playing silences it for the rest of this talk.
    currentId = detectSeg();
    if (playing) {
      stopMusic();
      musicDone = true;
    }
    render();
  };

  // S (or clicking the widget) toggles the talk clock: press when the
  // speaker starts, press again when they finish. Restart = two presses.
  const toggleTalk = () => {
    ensureAudio(); // user gesture — unlock audio for later
    stopMusic();
    musicDone = false;
    if (talkStart != null) {
      talkStart = null;
      runningSeg = null;
    } else {
      runningSeg = currentId ? (byId.get(currentId) ?? null) : null;
      talkStart = Date.now();
    }
    render();
  };

  // ± a minute off whichever segment the widget is showing — the running one
  // if the clock is going, otherwise the one on screen. Never drops a slot
  // below a minute, and never touches the clock itself, so it's safe mid-talk.
  const adjustBy = (deltaMins: number) => {
    const seg = talkStart != null && runningSeg ? runningSeg : currentId ? byId.get(currentId) : null;
    if (!seg) return;
    const talkMins = seg.mins - (seg.qa ?? 0);
    const next = Math.max(60 - talkMins * 60, adjustOf(seg) + deltaMins * 60);
    adjust.set(seg.id, next);
    render();
  };

  el.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".adj-btn") as HTMLElement | null;
    if (!btn) {
      toggleTalk();
      return;
    }
    // Don't let the ± buttons fall through to the widget's start/stop toggle,
    // and don't leave them focused (Reveal's keys should keep working).
    e.stopPropagation();
    btn.blur();
    adjustBy(Number(btn.dataset.delta));
  });
  // Capture phase + stopPropagation so our keys never reach Reveal — its
  // default binding for S opens the speaker-notes window.
  window.addEventListener(
    "keydown",
    (e) => {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA") return;
      const k = e.key.toLowerCase();
      const adjKey = k === "-" || k === "_" ? -1 : k === "+" || k === "=" ? 1 : 0;
      if (k !== "s" && k !== "m" && k !== "h" && !adjKey) return;
      e.preventDefault();
      e.stopPropagation();
      if (adjKey) adjustBy(adjKey);
      else if (k === "s") toggleTalk();
      else if (k === "m") {
        muted = !muted;
        if (muted) stopMusic();
        render();
      } else {
        el.classList.toggle("hidden");
      }
    },
    true,
  );

  const attach = () => {
    const r = document.querySelector(".reveal");
    if (!r) return false;
    r.addEventListener("slidechanged", onSlide);
    r.addEventListener("ready", onSlide);
    onSlide();
    return true;
  };
  if (!attach()) {
    const poll = setInterval(() => {
      if (attach()) clearInterval(poll);
    }, 200);
  }
  setInterval(render, 250);
  render();
</script>

<style is:global>
  .offsite-timer {
    position: fixed;
    right: 1.1rem;
    bottom: 1.1rem;
    z-index: 1000;
    min-width: 8.5rem;
    padding: 0.5rem 0.7rem 0.55rem;
    border-radius: 8px 0 8px 8px; /* the site's asymmetric corner */
    background: rgba(20, 16, 26, 0.72);
    backdrop-filter: blur(6px);
    color: #e0e0e0;
    font-family: ui-monospace, "SF Mono", "Cascadia Code", Menlo, Consolas,
      monospace;
    line-height: 1.15;
    text-align: right;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
    cursor: pointer;
    user-select: none;
    opacity: 0.62;
    transition: opacity 0.25s ease;
  }
  .offsite-timer:hover {
    opacity: 0.95;
  }
  .offsite-timer.idle {
    opacity: 0.4;
  }
  .offsite-timer.hidden {
    display: none;
  }
  .offsite-timer .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.55rem;
  }
  .offsite-timer .adj {
    display: flex;
    gap: 0.15rem;
    /* the controls stay out of the way until the widget is hovered */
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .offsite-timer:hover .adj,
  .offsite-timer:focus-within .adj {
    opacity: 1;
  }
  .offsite-timer .adj-btn {
    width: 1.15rem;
    height: 1.15rem;
    padding: 0;
    border: 1px solid rgba(224, 224, 224, 0.25);
    border-radius: 4px;
    background: transparent;
    color: inherit;
    font: inherit;
    font-size: 0.75rem;
    line-height: 1;
    cursor: pointer;
  }
  .offsite-timer .adj-btn:hover {
    border-color: #be2edd;
    color: #be2edd;
  }
  .offsite-timer .count {
    font-size: 1.65rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.01em;
  }
  .offsite-timer .count-ok {
    color: #56d364;
  }
  .offsite-timer .count-over {
    color: #f85149;
    animation: offsite-pulse 1.4s ease-in-out infinite;
  }
  .offsite-timer .count-idle {
    color: #9b8fb0;
  }
  .offsite-timer .status {
    font-size: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.3rem;
    opacity: 0.9;
  }
  .offsite-timer .dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: currentColor;
    flex: none;
  }
  .offsite-timer .status-ok {
    color: #56d364;
  }
  .offsite-timer .status-over {
    color: #f85149;
  }
  .offsite-timer .status-idle {
    color: #9b8fb0;
  }
  @keyframes offsite-pulse {
    50% {
      opacity: 0.55;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .offsite-timer .count-over {
      animation: none;
    }
    .offsite-timer,
    .offsite-timer .adj {
      transition: none;
    }
  }
</style>
