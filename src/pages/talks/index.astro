---
import { getCollection } from "astro:content"
import fs from "node:fs"
import path from "node:path"
import PageLayout from "../../layouts/PageLayout.astro"
import { formatDate, parseDate } from "../../utils/date"

const allTalks = await getCollection("talks")

const decksDir = path.resolve("src/decks")
const deckSlugs = new Set(
  fs
    .readdirSync(decksDir)
    .filter((f) => /\.deck\.mdx?$/.test(f))
    .map((f) => f.replace(/\.deck\.mdx?$/, "")),
)

const entries = allTalks
  .map((talk) => {
    const slug = talk.id.replace(/\.md$/, "")
    const dateStr = talk.data.date ?? "2000-01-01"
    return {
      slug,
      title: talk.data.title,
      hasDeck: deckSlugs.has(slug),
      dateStr,
      dateFormatted: formatDate(parseDate(String(dateStr))),
      event: talk.data.event,
      slides: talk.data.slides,
      paper: talk.data.paper,
      video: talk.data.video,
    }
  })
  .sort((a, b) => b.dateStr.localeCompare(a.dateStr))

const decks = entries.filter((e) => e.hasDeck)
const archive = entries.filter((e) => !e.hasDeck)
---

<PageLayout title="Talks" relativePath="src/pages/talks/index.astro">
  <p>Talks and presentations, newest first.</p>
  <hr />

  <ul class="post-list">
    {decks.map((talk) => (
      <li class="post-item">
        <a href={`/decks/${talk.slug}/`} class="post-item-title">{talk.title}</a>
        <span class="post-item-date">{talk.dateFormatted}</span>
        {talk.event && <span class="post-item-venue"> - {talk.event}</span>}
      </li>
    ))}
  </ul>

  {archive.length > 0 && (
    <>
      <h2>Earlier talks</h2>
      <p>
        Older talks, kept for the archive. The slides and papers are linked where
        they survive.
      </p>
      <ul class="post-list">
        {archive.map((talk) => (
          <li class="post-item">
            <span class="post-item-title">{talk.title}</span>
            <span class="post-item-date">{talk.dateFormatted}</span>
            {talk.event && <span class="post-item-venue"> - {talk.event}</span>}
            {(talk.slides || talk.paper || talk.video) && (
              <span class="post-item-links">
                {talk.slides && <a href={talk.slides}>slides</a>}
                {talk.paper && <a href={talk.paper}>paper</a>}
                {talk.video && <a href={talk.video}>video</a>}
              </span>
            )}
          </li>
        ))}
      </ul>
    </>
  )}
</PageLayout>
