---
import PageLayout from "../layouts/PageLayout.astro"

const description =
  "Short CV — Ben Swift, creative technologist working in the open at the intersection of AI, creative practice and public understanding."
---

<PageLayout
  title="Short CV"
  description={description}
  relativePath="src/pages/cv-short.astro"
>
  <article class="cv-short">
    <header class="cv-masthead">
      <h1>Ben Swift</h1>
      <p class="cv-role">Creative technologist &middot; artist-researcher</p>
      <p class="cv-affil">
        Senior Lecturer &amp; Cybernetic Studio Lead, ANU School of Cybernetics
      </p>
      <p class="cv-contact">
        <a href="https://benswift.me">benswift.me</a> &middot;
        <a href="mailto:ben.swift@anu.edu.au">ben.swift@anu.edu.au</a> &middot;
        Canberra, Australia
      </p>
    </header>

    <p class="cv-bio">
      Ben Swift is a creative technologist who works in the open. He started out
      as a live coder, writing software on stage that makes music while an
      audience watches the code change, and has treated the process as the thing
      worth showing ever since. He leads the Cybernetic Studio at the Australian
      National University, whose Human-Scale AI project makes machine learning
      legible: neural networks you can touch, language models you can hold, and
      hands-on workshops that have walked everyone from primary-school students
      to senior public servants through the machinery of a language model.
      Running underneath is a conviction that AI is a cultural question as much
      as a technical one, and that the people it acts on deserve to see how it
      works.
    </p>

    <section>
      <h2>Selected works</h2>
      <div class="cv-row">
        <span class="yr">2026&ndash;</span>
        <span
          ><strong>Slop Salon</strong> (with Jess Herrington). Six AI agents making
          art on a shared Bluesky feed, booted from identical files to test whether
          watching each other is enough to pull them into six distinct artists. The
          studio is public and the practice is the work: every agent's notebook and
          commit history is open to read.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2024&ndash;</span>
        <span
          ><strong>The LLM Library / LLMs Unplugged.</strong> A public-facing project
          that makes language models legible with no computer in the room: n-gram models
          you build and run by hand with pen, paper and dice, and a shelf of hardbound
          books that each hold a model trained on a single novel. The workshops have
          reached 600+ people from school classrooms to the senior public service; the
          books are exhibited artefacts in their own right. Written up for ACE 2026.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2024</span>
        <span
          ><strong>Perceptron Apparatus.</strong> A 1.2-metre wooden instrument of
          concentric sliders that runs a small neural network's matrix multiplications
          by hand: an abacus for deep learning.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2026</span>
        <span
          ><strong>LLM Brainscan.</strong> Every trainable parameter of a transformer
          mapped onto an 8K display, one pixel per weight, updating live as the model
          learns to write.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2026</span>
        <span
          ><strong>Imprint.</strong> A typesetter that presses an institution's visual
          identity over any document, genuine or fabricated, until the real and the
          invented read exactly alike.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2025</span>
        <span
          ><strong>APS AI Transparency Tracker.</strong> Automated monitoring of the
          AI transparency statements published by Australian Government departments,
          tracking how the policies shift over time.</span
        >
      </div>
    </section>

    <section>
      <h2>Selected exhibitions</h2>
      <div class="cv-row">
        <span class="yr">2025</span>
        <span><strong>Perceptron Apparatus.</strong> SXSW Sydney.</span>
      </div>
      <div class="cv-row">
        <span class="yr">2024</span>
        <span><strong>PANIC!</strong> SXSW Sydney.</span>
      </div>
    </section>

    <section>
      <h2>Selected talks &amp; public engagement</h2>
      <div class="cv-row">
        <span class="yr">2022</span>
        <span><strong>Cybernetic Futures.</strong> APS Strategic Futures Network.</span>
      </div>
      <div class="cv-row">
        <span class="yr">2021</span>
        <span
          ><strong>Livecoding for leverage.</strong> Design Guild NSW (invited).</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2020</span>
        <span
          ><strong>Teaching code with music and music with code.</strong> FutureSchools
          Conference.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2019</span>
        <span
          ><strong>Musical instructions.</strong> Lake Tuggeranong College STEM Camp.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2018</span>
        <span
          ><strong>The World Since Google.</strong> University of the Third Age (U3A).</span
        >
      </div>
    </section>

    <section>
      <h2>Selected performances</h2>
      <div class="cv-row">
        <span class="yr">2025</span>
        <span><strong>SMCClab Live #1.</strong> ANU School of Music, Canberra.</span>
      </div>
      <div class="cv-row">
        <span class="yr">2024</span>
        <span
          ><strong>Coloring Code</strong>, International Conference on Live Coding
          (ICLC). Shanghai Concert Hall, China.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2020</span>
        <span
          ><strong>ICLC&nbsp;'20 Algorave</strong>. Flannery's Bar, Limerick,
          Ireland.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2019</span>
        <span
          ><strong>Colour Coded</strong>, <em>The DNA of Colour</em> exhibition.
          Drill Hall Gallery, Canberra.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2014</span>
        <span
          ><strong>You Are Here Festival</strong>. Canberra Museum and Gallery.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2013</span>
        <span
          ><strong>MuMe Algorave</strong>, International Symposium on Electronic Art
          (ISEA). Sydney.</span
        >
      </div>
      <p class="cv-note">
        Selected from 25+ performances since 2008; full archive at <a
          href="https://benswift.me/livecoding/">benswift.me/livecoding</a
        >.
      </p>
    </section>

    <div class="cv-cols">
      <section>
        <h2>Fellowships &amp; grants</h2>
        <div class="cv-row">
          <span class="yr">2026</span>
          <span>Stateful AI Agents and Creative Collaboration (with Jess Herrington), ANU.</span>
        </div>
        <div class="cv-row">
          <span class="yr">2020&ndash;22</span>
          <span>Reimagine Fellowship: the c/c/c studio, ANU.</span>
        </div>
        <div class="cv-row">
          <span class="yr">2016,&nbsp;17</span>
          <span>ANU Vice-Chancellor's College Visiting Artist Fellowship.</span>
        </div>
      </section>

      <section>
        <h2>Education</h2>
        <div class="cv-row">
          <span class="yr">2012</span>
          <span>PhD, Computer Science, Australian National University.</span>
        </div>
        <div class="cv-row">
          <span class="yr">2007</span>
          <span>BSc (Hons I), mathematics and physics, ANU.</span>
        </div>
        <div class="cv-row">
          <span class="yr">2005</span>
          <span>Certificate IV in Music Performance, Canberra Institute of Technology.</span>
        </div>
      </section>
    </div>

    <section>
      <h2>Selected writing</h2>
      <div class="cv-row">
        <span class="yr">2026</span>
        <span
          >LLMs Unplugged: Teaching Resources for a ChatGPT World. <em
            >Australasian Computing Education Conference (ACE)</em
          >.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2025</span>
        <span
          >Emerging Paradigms in Human&ndash;AI Creativity. <em
            >Human-Computer Creativity</em
          > (book chapter).</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2020</span>
        <span>Camera Adversaria. <em>CHI</em>.</span>
      </div>
      <div class="cv-row">
        <span class="yr">2018</span>
        <span
          >The Other Side: Algorithm as Ritual in Artificial Intelligence. <em
            >alt.CHI</em
          >.</span
        >
      </div>
      <div class="cv-row">
        <span class="yr">2014</span>
        <span>The Many Meanings of Live Coding. <em>Computer Music Journal</em>.</span>
      </div>
    </section>

    <p class="cv-foot">
      Full CV, complete publication list and performance archive at <a
        href="https://benswift.me/cv/">benswift.me/cv</a
      >.
    </p>
  </article>
</PageLayout>

<style is:global>
  /* Hide the layout's auto page-title; this page uses its own masthead. */
  body:has(.cv-short) .page-title {
    display: none;
  }

  .cv-short {
    max-width: 54rem;
    margin-inline: auto;
  }

  .cv-masthead h1 {
    margin-bottom: 0.1rem;
  }

  .cv-role {
    color: var(--brand-1, #be2edd);
    font-weight: 600;
    margin: 0.1rem 0;
  }

  .cv-affil {
    margin: 0.1rem 0;
  }

  .cv-contact {
    color: var(--text-2, #aaa);
    font-size: 0.95rem;
    margin: 0.1rem 0 0;
  }

  .cv-bio {
    margin: 1rem 0 0.5rem;
  }

  .cv-short section {
    margin-top: 0.5rem;
  }

  .cv-short h2 {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--divider, #555);
    padding-bottom: 0.2rem;
    margin: 1.3rem 0 0.5rem;
  }

  .cv-row {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    gap: 0.75rem;
    margin: 0.3rem 0;
    align-items: baseline;
  }

  .cv-row .yr {
    color: var(--text-3, #888);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .cv-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 2rem;
  }

  .cv-note {
    color: var(--text-3, #888);
    font-size: 0.85rem;
    margin: 0.4rem 0 0;
    padding-left: 5.25rem;
  }

  .cv-foot {
    color: var(--text-2, #aaa);
    font-size: 0.9rem;
    margin-top: 1.3rem;
  }

  @media (max-width: 32rem) {
    .cv-cols {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .cv-row {
      grid-template-columns: 3.5rem 1fr;
      gap: 0.5rem;
    }
    .cv-note {
      padding-left: 0;
    }
  }

  /* Two-page print layout */
  @page {
    size: A4;
    margin: 13mm 15mm;
  }

  @media print {
    body:has(.cv-short) .hero-slot {
      display: none !important;
    }

    .cv-short {
      max-width: none;
      font-size: 10.7pt;
      line-height: 1.42;
    }

    .cv-masthead h1 {
      font-size: 22pt;
      margin: 0 0 0.1rem;
    }

    .cv-role,
    .cv-affil,
    .cv-contact {
      font-size: 10pt;
    }

    .cv-bio {
      margin: 0.6rem 0 0.3rem;
    }

    .cv-short h2 {
      font-size: 11.5pt;
      margin: 0.85rem 0 0.35rem;
      padding-bottom: 0.12rem;
      break-after: avoid;
    }

    .cv-short section {
      margin-top: 0.4rem;
    }

    /* Keep the two-column block together; let long lists flow across pages */
    .cv-cols {
      break-inside: avoid;
    }

    .cv-row {
      grid-template-columns: 3.6rem 1fr;
      gap: 0.65rem;
      margin: 0.26rem 0;
    }

    .cv-note {
      font-size: 8.6pt;
      padding-left: 4.25rem;
      margin: 0.25rem 0 0;
    }

    .cv-foot {
      font-size: 9pt;
      margin-top: 0.9rem;
    }
  }
</style>
